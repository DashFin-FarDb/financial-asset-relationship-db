{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "SLO Compliance Status",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "slo_compliance_status",
          "legendFormat": "{{slo_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "BREACHED", "color": "red" }, "1": { "text": "COMPLIANT", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "Error Budget Consumption (24h)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "((sum(rate(http_requests_total{status_group=~\"5..\"}[24h])) or vector(0)) / sum(rate(http_requests_total[24h]))) / (1 - 0.99) * 100",
          "legendFormat": "Budget Used (%)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "Compliance Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "slo_compliance_status",
          "legendFormat": "{{slo_name}}"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["slo", "compliance"],
  "title": "SLO Compliance",
  "version": 1
}
